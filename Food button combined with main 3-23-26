import time

pygame.init()

# Screen setup
WIDTH, HEIGHT = 800, 600
screen = pygame.display.set_mode((WIDTH, HEIGHT))
pygame.display.set_caption("State Machine Demo")

BLACK = (0, 0, 0)
clock = pygame.time.Clock()

font1=pygame.font.SysFont("arial",48,True)
text1=font1.render("intructions/tutorial",True,(0,0,0))
text2=font1.render("tropical tank",True,(0,0,0))
text3=font1.render("freshwater tank",True,(0,0,0))
text4=font1.render("fish collection book",True,(0,0,0))


# ========= FISH =========
class Fish:#tbh i just copy andd paste
    def __init__(self):
        self.fishImage = pygame.image.load("BlueFish.png").convert_alpha()
        pygame.Surface.set_colorkey(self.fishImage, [255,0,255])
        self.xpos = random.randint(0, 750)
        self.ypos = random.randint(0, 550)
        self.speed = 1
        self.xDir = random.randint(-1,1)
        self.yDir = random.randint(-1,1)
        self.last_change_time = time.time()

    def move(self, food_x, food_y, food_falling):
        #follow food
        if food_falling:
            if self.xpos < food_x:
                self.xDir = 1
            elif self.xpos > food_x:
                self.xDir = -1

            if self.ypos < food_y:
                self.yDir = 1
            elif self.ypos > food_y:
                self.yDir = -1
        else:
            #random movement
            if time.time() - self.last_change_time > 3:
                self.xDir = random.randint(-1,1)
                self.yDir = random.randint(-1,1)
                self.last_change_time = time.time()

        #move
        self.xpos += self.xDir * self.speed
        self.ypos += self.yDir * self.speed

        #when collides with walls turn back
        if self.xpos <= 0 or self.xpos >= 750:
            self.xDir *= -1
        if self.ypos <= 0 or self.ypos >= 550:
            self.yDir *= -1
        
    def draw(self):
        screen.blit(self.fishImage, (self.xpos, self.ypos))


