# === Tropical tank State ===
class ttankstate:
    def __init__(self):
        self.bg_color = (0, 100,0)
        self.door = pygame.Rect(10, 10, 50, 50)

        # fish stuff 
        self.fish = Fish()

        self.food_size = 10
        self.food_x = 0
        self.food_y = 0
        self.food_falling = False
        self.food_speed = 1

        self.button_rect = pygame.Rect(650, 10, 140, 40)
        self.font = pygame.font.SysFont(None, 24)

    def update(self):
        self.fish.move(self.food_x, self.food_y, self.food_falling)

        if self.food_falling:
            self.food_y += self.food_speed

        fish_rect = pygame.Rect(self.fish.xpos, self.fish.ypos,
                                self.fish.fishImage.get_width(),
                                self.fish.fishImage.get_height())

        food_rect = pygame.Rect(self.food_x, self.food_y,
                                self.food_size, self.food_size)

        if fish_rect.colliderect(food_rect):
            self.food_falling = False
            self.fish.fishImage = pygame.transform.scale(
                self.fish.fishImage,
                (self.fish.fishImage.get_width()+2,
                 self.fish.fishImage.get_height()+2)
            )

        if self.food_y > 900:
            self.food_falling = False

    def draw(self):
        screen.fill(self.bg_color)
        self.fish.draw()

        if self.food_falling:
            pygame.draw.rect(screen, (255,200,0),
                             (self.food_x, self.food_y,
                              self.food_size, self.food_size))

        pygame.draw.rect(screen, (200,200,200), self.button_rect)
        text = self.font.render("Feed Fish", True, (0,0,0))
        screen.blit(text, (self.button_rect.x+20, self.button_rect.y+10))

        pygame.draw.rect(screen, BLACK, self.door)


